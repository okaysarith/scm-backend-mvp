# SCM Network Analysis MVP Environment Variables

# Azure Blob Storage URLs
BASELINE_DATA_URL=https://scmdata2026.blob.core.windows.net/data/combined_df.csv
MASTER_DATA_URL=https://scmdata2026.blob.core.windows.net/data/Master_data_with_pincodes.csv

# MVP Configuration
MVP_MODE=true
ENVIRONMENT=development
STORAGE_TYPE=sqlite
MAX_FILE_SIZE_MB=20
REQUEST_TIMEOUT_SECONDS=25

# CORS Configuration (for production)
CORS_ORIGINS=https://your-frontend-domain.com,https://another-domain.com

# Database (if needed)
# DATABASE_URL=sqlite:///./data/scm_database.db
